{
  "name": "obsidian-strategic-document-management",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=node --external:obsidian --watch",
    "build": "esbuild src/main.ts --bundle --minify --sourcemap --outfile=main.js --format=cjs --platform=node --external:obsidian",
    "build:cli": "esbuild src/cli.ts --bundle --outfile=dist/cli.js --format=cjs --platform=node --external:obsidian --banner:js='#!/usr/bin/env node'",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "esbuild": "^0.25.11",
    "eslint": "^9.38.0",
    "jsdom": "^27.0.1",
    "obsidian": "^1.13.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "bin": {
    "utd-sdm": "./dist/cli.js"
  }
}
